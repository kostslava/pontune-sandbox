# Piston API base URL (HTTP). Used by the Vite dev-server proxy.
PISTON_URL=http://localhost:2000

# Piston WebSocket base URL. Used for production builds only.
VITE_PISTON_URL=ws://localhost:2000

# Remote / port-forwarded Piston (uncomment and set your public IP or hostname):
# PISTON_URL=http://142.114.117.104:2000
# VITE_PISTON_URL=ws://142.114.117.104:2000
